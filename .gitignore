Session.vim

# tmux logs
tmux-client-*.log
tmux-server-*.log
*.log

# macOS
.DS_Store
.DS_Store?
._*

# Linux
.Trash-*

# Windows
Thumbs.db

# Editor cruft
*.swp
*.swo
*~

# Local-only tooling state
.omc/
# Claude Code project-local state for THIS repo
/.claude/

# Third-party plugin caches dropped into stowed package dirs at runtime
vim/.vim/autoload/
vim/.vim/plugged/
vim/.vim/bundle/
tmux/.tmux/plugins/

# Local overrides and secrets
*.local
*.secret
.env
.env.*

# Negations: files we DO want tracked despite the *.local rule above
!tmux/.tmux.conf.local
