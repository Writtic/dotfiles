Session.vim

# tmux logs
tmux-client-*.log
tmux-server-*.log
*.log

# macOS
.DS_Store
.DS_Store?
._*

# Linux
.Trash-*

# Windows
Thumbs.db

# Editor cruft
*.swp
*.swo
*~

# Local-only tooling state
.omc/
# Claude Code project-local state for THIS repo
/.claude/

# All docs/ are local-only working notes — brainstorm specs, implementation
# plans (superpowers), ce-compound learnings, design notes. Kept on disk so
# they don't pile up in the repo or confuse teammates who can't access them.
# Use docs/* (not docs/) so a specific file can still be re-included with !.
docs/*

# Third-party plugin caches dropped into stowed package dirs at runtime
vim/.vim/autoload/
vim/.vim/plugged/
vim/.vim/bundle/
tmux/.tmux/plugins/

# Claude Code (claude/ stow package) — whitelist tracked files only.
# Everything under claude/.claude/ is ignored except the explicit !-entries below.
# Rationale: ~/.claude/ contains heavy runtime state (sessions, todos, cache,
# history.jsonl, paste-cache, ...) and secrets (auth tokens). We only track
# user-authored config + plugin manifest pins.
claude/.claude/*
!claude/.claude/CLAUDE.md
!claude/.claude/settings.json
!claude/.claude/.mcp.json
!claude/.claude/agents/
!claude/.claude/commands/
!claude/.claude/hooks/
!claude/.claude/skills/
# plugins/ is intentionally NOT tracked. Both known_marketplaces.json and
# installed_plugins.json are machine-state regenerated by /plugin from
# `extraKnownMarketplaces` + `enabledPlugins` in settings.json (source of truth).
# Inside skills/, third-party skills (their own .git, package.json, bin/) are
# installed at runtime — track only user-authored skills you commit by hand.
claude/.claude/skills/*/.git/
claude/.claude/skills/*/node_modules/
claude/.claude/skills/*/bun.lock

# Local overrides and secrets
*.local
*.secret
.env
.env.*

# Negations: files we DO want tracked despite the *.local rule above
!tmux/.tmux.conf.local
